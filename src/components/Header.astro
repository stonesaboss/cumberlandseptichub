---
import {
  SITE_NAME,
  PHONE_DISPLAY,
  PHONE_TEL,
  UTILITY_BAR_TEXT,
  SERVICES_DROPDOWN,
  AREAS_DROPDOWN,
} from '@data/site';
---

<div class="utility-bar">
  <div class="container utility-bar__inner">
    <p class="utility-bar__serving">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/></svg>
      {UTILITY_BAR_TEXT}
    </p>
    <p class="utility-bar__phone">
      Need Septic Service? <a href={`tel:${PHONE_TEL}`} data-analytics="header-phone-click">Call <strong>{PHONE_DISPLAY}</strong></a>
    </p>
  </div>
</div>

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__brand" aria-label={`${SITE_NAME} — home`}>
      <img
        src="/logos/emblem-120.png"
        srcset="/logos/emblem-120.png 1x, /logos/emblem-240.png 2x"
        alt=""
        width="52"
        height="52"
        class="site-header__emblem"
      />
      <span class="site-header__name">
        <span class="site-header__name-top">Cumberland</span>
        <span class="site-header__name-bottom">Septic Hub</span>
      </span>
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="primary-nav"
    >
      <span class="nav-toggle__bars" aria-hidden="true"></span>
      <span class="nav-toggle__label">Menu</span>
    </button>

    <nav class="site-nav" id="primary-nav" aria-label="Primary">
      <ul class="site-nav__list">
        <li><a href="/">Home</a></li>
        <li class="site-nav__dropdown">
          <button type="button" aria-expanded="false" aria-controls="menu-services">
            Septic Services
            <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true"><path d="M1 3l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.8"/></svg>
          </button>
          <ul class="site-nav__menu" id="menu-services">
            {SERVICES_DROPDOWN.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </li>
        <li><a href="/septic-pumping-cookeville-tn/">Septic Pumping</a></li>
        <li><a href="/septic-repair-cookeville-tn/">Septic Repair</a></li>
        <li><a href="/septic-installation-cookeville-tn/">Installation</a></li>
        <li class="site-nav__dropdown">
          <button type="button" aria-expanded="false" aria-controls="menu-areas">
            Service Areas
            <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true"><path d="M1 3l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.8"/></svg>
          </button>
          <ul class="site-nav__menu" id="menu-areas">
            {AREAS_DROPDOWN.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </li>
        <li><a href="/#faqs">FAQs</a></li>
        <li class="site-nav__cta-item">
          <a href="/request-service/" class="btn btn--green site-nav__cta" data-analytics="header-request-cta">Request Septic Service</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .utility-bar {
    background: var(--navy-dark);
    color: #d7e3ec;
    font-size: 0.88rem;
  }

  .utility-bar__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    min-height: 38px;
    flex-wrap: wrap;
  }

  .utility-bar p {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding-block: 0.3rem;
  }

  .utility-bar a {
    color: var(--white);
    text-decoration: none;
  }

  .utility-bar a:hover {
    text-decoration: underline;
    color: var(--white);
  }

  .utility-bar strong {
    color: #7fd0a0;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--white);
    border-bottom: 1px solid var(--border-gray);
    box-shadow: 0 1px 6px rgba(13, 41, 66, 0.06);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 68px;
  }

  .site-header__brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    padding-block: 0.4rem;
  }

  .site-header__emblem {
    width: 52px;
    height: 52px;
  }

  .site-header__name {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }

  .site-header__name-top {
    font-weight: 900;
    font-size: 1.15rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--navy-deep);
  }

  .site-header__name-bottom {
    font-weight: 800;
    font-size: 0.85rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--green);
  }

  .nav-toggle {
    display: none;
    align-items: center;
    gap: 0.5rem;
    background: none;
    border: 2px solid var(--navy-deep);
    border-radius: var(--radius);
    padding: 0.5rem 0.85rem;
    font-weight: 700;
    color: var(--navy-deep);
    cursor: pointer;
    min-height: 44px;
  }

  .nav-toggle__bars {
    display: block;
    width: 18px;
    height: 2px;
    background: currentColor;
    position: relative;
  }

  .nav-toggle__bars::before,
  .nav-toggle__bars::after {
    content: '';
    position: absolute;
    left: 0;
    width: 18px;
    height: 2px;
    background: currentColor;
  }

  .nav-toggle__bars::before {
    top: -6px;
  }

  .nav-toggle__bars::after {
    top: 6px;
  }

  .site-nav__list {
    display: flex;
    align-items: center;
    gap: 0.1rem;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: nowrap;
  }

  .site-nav__list > li > a,
  .site-nav__dropdown > button {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.6rem 0.55rem;
    font-size: 0.9rem;
    font-weight: 700;
    white-space: nowrap;
    color: var(--navy-deep);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    border-radius: var(--radius);
  }

  /* the CTA keeps its .btn--green styling — exclude it from nav-link rules */
  .site-nav__list > li > a:not(.site-nav__cta):hover,
  .site-nav__dropdown > button:hover {
    color: var(--green-dark);
    background: var(--bg-pale);
  }

  .site-nav__list > li > a.site-nav__cta {
    background: var(--green);
    color: var(--white);
  }

  .site-nav__list > li > a.site-nav__cta:hover {
    background: var(--green-dark);
    color: var(--white);
  }

  .site-nav__dropdown {
    position: relative;
  }

  .site-nav__menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 270px;
    background: var(--white);
    border: 1px solid var(--border-gray);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card-hover);
    list-style: none;
    margin: 0;
    padding: 0.4rem;
    z-index: 50;
  }

  .site-nav__dropdown[data-open] .site-nav__menu {
    display: block;
  }

  .site-nav__menu a {
    display: block;
    padding: 0.55rem 0.8rem;
    text-decoration: none;
    color: var(--text);
    font-size: 0.95rem;
    border-radius: 6px;
  }

  .site-nav__menu a:hover {
    background: var(--bg-pale);
    color: var(--green-dark);
  }

  .site-nav__cta {
    font-size: 0.8rem;
    padding: 0.65rem 0.9rem;
    margin-left: 0.35rem;
    white-space: nowrap;
  }

  @media (max-width: 1120px) {
    .nav-toggle {
      display: inline-flex;
    }

    .site-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--white);
      border-bottom: 1px solid var(--border-gray);
      box-shadow: 0 12px 24px rgba(13, 41, 66, 0.14);
      max-height: calc(100vh - 110px);
      overflow-y: auto;
    }

    .site-nav[data-open] {
      display: block;
    }

    .site-nav__list {
      flex-direction: column;
      align-items: stretch;
      padding: 0.75rem 1rem 1.25rem;
      gap: 0;
    }

    .site-nav__list > li {
      border-bottom: 1px solid var(--bg-pale);
    }

    .site-nav__list > li:last-child {
      border-bottom: none;
    }

    .site-nav__list > li > a,
    .site-nav__dropdown > button {
      display: flex;
      width: 100%;
      justify-content: space-between;
      padding: 0.85rem 0.5rem;
      font-size: 1.05rem;
    }

    .site-nav__menu {
      position: static;
      box-shadow: none;
      border: none;
      border-left: 3px solid var(--border-gray);
      border-radius: 0;
      margin: 0 0 0.5rem 0.75rem;
    }

    .site-nav__cta-item {
      padding-top: 0.85rem;
    }

    .site-nav__cta {
      width: 100%;
      margin-left: 0;
    }
  }
</style>

<script>
  // Mobile nav toggle + accessible dropdowns
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const nav = document.getElementById('primary-nav');

  toggle?.addEventListener('click', () => {
    const open = nav?.hasAttribute('data-open');
    if (open) {
      nav?.removeAttribute('data-open');
      toggle.setAttribute('aria-expanded', 'false');
    } else {
      nav?.setAttribute('data-open', '');
      toggle.setAttribute('aria-expanded', 'true');
    }
  });

  const dropdowns = document.querySelectorAll<HTMLElement>('.site-nav__dropdown');

  const closeAll = (except?: HTMLElement) => {
    dropdowns.forEach((dd) => {
      if (dd !== except) {
        dd.removeAttribute('data-open');
        dd.querySelector('button')?.setAttribute('aria-expanded', 'false');
      }
    });
  };

  dropdowns.forEach((dd) => {
    const btn = dd.querySelector('button');
    btn?.addEventListener('click', () => {
      const isOpen = dd.hasAttribute('data-open');
      closeAll(dd);
      if (isOpen) {
        dd.removeAttribute('data-open');
        btn.setAttribute('aria-expanded', 'false');
      } else {
        dd.setAttribute('data-open', '');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('.site-nav__dropdown')) closeAll();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeAll();
      if (nav?.hasAttribute('data-open')) {
        nav.removeAttribute('data-open');
        toggle?.setAttribute('aria-expanded', 'false');
        toggle?.focus();
      }
    }
  });
</script>
