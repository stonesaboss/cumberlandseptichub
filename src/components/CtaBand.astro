---
import { PHONE_DISPLAY, PHONE_TEL } from '@data/site';

interface Props {
  heading?: string;
  copy?: string;
  primaryLabel?: string;
}

const {
  heading = 'Request Septic Pumping, Repair or Installation',
  copy = 'Tell us where the property is located, what symptoms you are experiencing and which type of septic service you may need.',
  primaryLabel = 'Request Septic Service',
} = Astro.props;
---

<section class="section cta-band">
  <div class="container cta-band__inner">
    <h2>{heading}</h2>
    <p>{copy}</p>
    <div class="cta-band__actions">
      <a href="/request-service/" class="btn btn--green" data-analytics="cta-band-request">{primaryLabel}</a>
      <a href={`tel:${PHONE_TEL}`} class="btn btn--outline-light" data-analytics="cta-band-call">Call {PHONE_DISPLAY}</a>
    </div>
  </div>
</section>

<style>
  .cta-band {
    background:
      linear-gradient(rgba(7, 28, 45, 0.88), rgba(13, 41, 66, 0.92)),
      url('/images/rural-property.svg') center / cover no-repeat;
    color: #e8f0f4;
    text-align: center;
  }

  .cta-band h2 {
    color: var(--white);
  }

  .cta-band p {
    max-width: 42rem;
    margin-inline: auto;
    font-size: 1.1rem;
    color: #c6d6e0;
  }

  .cta-band__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
</style>
