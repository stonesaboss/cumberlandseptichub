---
import Base from '@layouts/Base.astro';
import { PHONE_DISPLAY, PHONE_TEL } from '@data/site';
---

<Base
  title="Request Received | Cumberland Septic Hub"
  description="Your septic service request has been received. A provider may contact you if coverage and availability fit the request."
  noindex={true}
>
  <div class="section">
    <div class="container" style="max-width:44rem; text-align:center;">
      <div class="thanks-card">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.8" aria-hidden="true" style="margin-inline:auto;">
          <circle cx="12" cy="12" r="10" />
          <path d="M8 12.5l2.6 2.6L16 9.5" />
        </svg>
        <h1>Request Received</h1>
        <p class="thanks-ref" data-thanks-ref hidden>
          Reference number: <strong data-thanks-ref-value></strong>
        </p>
        <p>
          Your septic service request has been submitted. A provider may contact you if coverage
          and availability fit the request.
        </p>
        <p>
          In the meantime: if sewage is actively backing up, reduce water use and avoid contact
          with wastewater. If your situation changes or becomes urgent, call
          <a href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a>.
        </p>
        <div class="thanks-actions">
          <a href="/" class="btn btn--navy">Back to Homepage</a>
          <a href="/septic-maintenance/" class="btn btn--outline-navy">Septic Maintenance Guide</a>
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  // Show the reference number passed by the form redirect — either as a
  // path segment (/thank-you/{leadId}, served via a 200 rewrite in
  // public/_redirects) or as ?ref=. Thank-you page views are tracked
  // without any personal data.
  const pathRef = decodeURIComponent(
    window.location.pathname.replace(/^\/thank-you\/?/, '').replace(/\/$/, ''),
  );
  const ref = pathRef || new URLSearchParams(window.location.search).get('ref');
  if (ref && /^CSH-[A-Z0-9-]{4,30}$/.test(ref)) {
    const wrap = document.querySelector<HTMLElement>('[data-thanks-ref]');
    const value = document.querySelector<HTMLElement>('[data-thanks-ref-value]');
    if (wrap && value) {
      value.textContent = ref;
      wrap.hidden = false;
    }
  }
  window.dataLayer?.push({ event: 'thank_you_view' });
</script>

<style>
  .thanks-card {
    background: var(--white);
    border: 1px solid var(--border-gray);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: 3rem 2rem;
  }

  .thanks-card h1 {
    margin-top: 1rem;
  }

  .thanks-ref {
    font-size: 1.1rem;
    color: var(--green-dark);
  }

  .thanks-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.75rem;
  }
</style>
