---
import ServicePage from '@layouts/ServicePage.astro';
import type { Faq } from '@data/site';

const faqs: Faq[] = [
  {
    question: 'My alarm is sounding — what does that usually mean?',
    answer:
      'Alarms on pumped or aerated systems typically indicate high water in a chamber, a pump that is not running, or a treatment component fault. Silencing the alarm does not fix the cause. Reduce water use and request an evaluation; note the alarm in the form.',
  },
  {
    question: 'The backup came back a week after pumping. Is that a repair issue?',
    answer:
      'Very likely. A tank refills with liquid within days of pumping — that is normal — but sewage backing up again quickly points to a blockage, a failed component or a drain field that can no longer accept water. Pumping again usually will not change the outcome.',
  },
  {
    question: 'Can anyone diagnose the problem over the phone or from this website?',
    answer:
      'No. Symptoms overlap too much — a full tank, a crushed pipe and a saturated drain field can all look like “slow drains.” This website cannot diagnose your system; a provider needs to evaluate the property before the cause and the repair can be identified.',
  },
  {
    question: 'When is replacement more practical than repair?',
    answer:
      'When major components have reached end of life, the drain field has failed, or repeated repairs no longer hold. That decision depends on an on-site evaluation, system age, site conditions and applicable requirements — not on a website checklist.',
  },
];
---

