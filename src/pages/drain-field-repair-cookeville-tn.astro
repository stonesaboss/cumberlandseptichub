---
import ServicePage from '@layouts/ServicePage.astro';
import type { Faq } from '@data/site';

const faqs: Faq[] = [
  {
    question: 'Why is my grass greenest in stripes over the field lines?',
    answer:
      'Vegetation that outgrows the surrounding lawn in lines or patches over the drain field can mean effluent is rising toward the surface instead of soaking away below root depth. On its own it is a warning sign, not a diagnosis — an evaluation is needed.',
  },
  {
    question: 'Does a failed drain field always mean full replacement?',
    answer:
      'No single answer applies. Outcomes depend on the cause: a crushed line or a tilted distribution box is a different problem than soil that can no longer accept water. A provider must evaluate the field before any repair approach can be recommended.',
  },
  {
    question: 'Can I drive or park over my drain field?',
    answer:
      'Vehicles compact soil and can crush field lines — traffic over the field is one of the recognized causes of damage. If part of your field doubles as parking, mention it in the request; it is relevant to diagnosis.',
  },
  {
    question: 'Rain makes my drains slow. Is that a drain-field sign?',
    answer:
      'It can be. A field near its limits often struggles when the surrounding soil is saturated by heavy rain. Symptoms that track the weather are worth describing in the request exactly that way.',
  },
];
---

<ServicePage
  title="Drain-Field Repair in Cookeville, TN"
