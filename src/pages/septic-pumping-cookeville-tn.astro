---
import ServicePage from '@layouts/ServicePage.astro';
import type { Faq } from '@data/site';

const faqs: Faq[] = [
  {
    question: 'How do I know if my tank needs pumping or if something is broken?',
    answer:
      'A tank that has simply filled with solids usually causes gradual symptoms — slower drains, occasional odors and eventually backups. Sudden failures, alarms or wastewater surfacing outdoors can point to a damaged component or drain-field problem instead. A provider can often tell the difference once the tank is opened.',
  },
  {
    question: 'What should I have ready before requesting pumping in Cookeville?',
    answer:
      'The property address or nearest crossroad, whether the tank location is known, roughly when it was last pumped, and any current symptoms. Notes about driveway access, gates, pets or steep terrain also help a provider plan the visit.',
  },
  {
    question: 'Does the truck need to park close to the tank?',
    answer:
      'Vacuum trucks work through heavy hoses with practical length limits, so access matters. Long distances, fences, slopes or soft ground can affect whether and how a provider can service the tank — mention anything unusual in the request.',
  },
  {
    question: 'Will the lids be dug up as part of the service?',
    answer:
      'Practices differ. Some providers include shallow lid excavation, others charge separately or ask the owner to expose lids in advance. Confirm what is included when a provider contacts you.',
  },
];
---

