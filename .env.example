# Cumberland Septic Hub — environment variables
# Copy to .env for local builds and set real values in the
# Cloudflare Pages dashboard (Settings → Environment variables).
# NEVER commit real values. Secret values belong in .dev.vars locally.

# Canonical production URL (no trailing slash). Drives canonicals,
# sitemap, Open Graph and structured-data URLs.
PUBLIC_SITE_URL=

# Cloudflare Turnstile (site key is public, secret is server-side only)
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Lead delivery — webhook and/or email provider
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_SECRET=
FORM_RECIPIENT_EMAIL=
EMAIL_API_KEY=

# Analytics (optional until configured)
PUBLIC_ANALYTICS_ID=
TAG_MANAGER_ID=

# Server-side secrets for local `wrangler pages dev` live in .dev.vars —
# see .dev.vars.example for the full list (TURNSTILE_SECRET_KEY,
# LEAD_WEBHOOK_URL, LEAD_WEBHOOK_SECRET, DEV_MODE, ...).
